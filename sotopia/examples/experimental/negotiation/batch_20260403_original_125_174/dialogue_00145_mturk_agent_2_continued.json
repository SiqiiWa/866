      "speaker": "mturk_agent_1",
      "listener": "mturk_agent_2"
    },
    {
      "text": "Hi.  I can't do that right now.",
      "task_data": {
        "data": "",
        "issue2youget": {
          "Firewood": "",
          "Water": "",
          "Food": ""
        },
