      "turn_id": "dialogue_00145_turn_02",
      "speaker": "mturk_agent_2",
      "listener": "mturk_agent_1"
    },
    {
      "text": "Is there anything that you might need? ",
      "task_data": {
        "data": "",
        "issue2youget": {
          "Firewood": "",
          "Water": "",
          "Food": ""
        },
        "issue2theyget": {
