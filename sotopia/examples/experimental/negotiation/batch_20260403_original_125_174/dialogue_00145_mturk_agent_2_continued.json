          "Food": ""
        }
      },
      "id": "mturk_agent_1",
      "turn_index": 9,
      "turn_id": "dialogue_00145_turn_09",
      "speaker": "mturk_agent_1",
      "listener": "mturk_agent_2"
    },
    {
      "text": "I do actually!  I can give you 3 foods. Would that work?",
      "task_data": {
        "data": "",
        "issue2youget": {
          "Firewood": "",
          "Water": "",
          "Food": ""
        },
        "issue2theyget": {
          "Firewood": "",
          "Water": "",
          "Food": ""
        }
      },
      "id": "mturk_agent_2",
