      "turn_index": 8,
      "turn_id": "dialogue_00145_turn_08",
      "speaker": "mturk_agent_2",
      "listener": "mturk_agent_1"
    },
    {
      "text": "Do you have food? I have been trying to hunt but have not really found any animals nearby to hunt.",
      "task_data": {
        "data": "",
        "issue2youget": {
          "Firewood": "",
          "Water": "",
          "Food": ""
        },
        "issue2theyget": {
          "Firewood": "",
