      "speaker": "mturk_agent_2",
      "listener": "mturk_agent_1"
    },
    {
      "text": "Well I need some food because what if I get lost as well? ",
      "task_data": {
        "data": "",
        "issue2youget": {
          "Firewood": "",
          "Water": "",
          "Food": ""
        },
        "issue2theyget": {
