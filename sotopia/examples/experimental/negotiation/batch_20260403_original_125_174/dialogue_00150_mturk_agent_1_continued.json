      "turn_id": "dialogue_00150_turn_04",
      "speaker": "mturk_agent_2",
      "listener": "mturk_agent_1"
    },
    {
      "text": "Ok.  So I'll get 2 water and you'll get 1 water?",
      "task_data": {
        "data": "",
        "issue2youget": {
          "Firewood": "",
          "Water": "",
          "Food": ""
        },
        "issue2theyget": {
