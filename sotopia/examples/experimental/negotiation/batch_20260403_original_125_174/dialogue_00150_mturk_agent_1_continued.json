      "turn_id": "dialogue_00150_turn_03",
      "speaker": "mturk_agent_1",
      "listener": "mturk_agent_2"
    },
    {
      "text": "Me too. How about you can have 2 water and 1 food if you give me 2 firewood?",
      "task_data": {
        "data": "",
        "issue2youget": {
          "Firewood": "",
          "Water": "",
          "Food": ""
        },
        "issue2theyget": {
