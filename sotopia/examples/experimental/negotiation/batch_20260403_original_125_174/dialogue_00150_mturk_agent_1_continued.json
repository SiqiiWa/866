        }
      },
      "id": "mturk_agent_1",
      "turn_index": 1,
      "turn_id": "dialogue_00150_turn_01",
      "speaker": "mturk_agent_1",
      "listener": "mturk_agent_2"
    },
    {
      "text": "Me too!!! I love camping! All that activity gets me wanting to indulge on snacks and then water to quench my thirst!",
      "task_data": {
        "data": "",
        "issue2youget": {
          "Firewood": "",
          "Water": "",
          "Food": ""
