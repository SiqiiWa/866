          "Food": ""
        }
      },
      "id": "mturk_agent_1",
      "turn_index": 4,
      "turn_id": "dialogue_00127_turn_04",
      "speaker": "mturk_agent_1",
      "listener": "mturk_agent_2"
    },
    {
      "text": "Looks like we both really need the food.  If you get 2 food I would need 1 food, 2 water and 3 firewood. ",
      "task_data": {
